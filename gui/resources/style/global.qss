/* ------ Labels ------ */
QLabel[lbl-level="h2"] {
    color: #374151;
    font-weight: bold;
    font-size: 16px;
}

QLabel[lbl-level="h3"] {
    color: #374151;
    font-weight: bold;
    font-size: 14px;
}

QLabel[lbl-level="h3-normal"] {
    color: #374151;
    font-weight: normal;
    font-size: 14px;
}

QLabel[lbl-level="p"] {
    font-weight: 400;
    font-size: 14px;
}

QLabel[lbl-level="lbl"] {
    font-weight: 400;
    font-size: 12px;
    /* font-family: "Arial"; */
    color: #626872;
}

/* ------ Buttons ------ */

QPushButton[btn-size="small"] {
    padding: 3px 7px 3px 7px;
    font-size: 12px;
    font-weight: bold;
    border-radius: 3px;
}


QPushButton[btn-size="large"] {
    padding: 10px;
    font-size: 14px;
    font-weight: bold;
    border-radius: 8px;
    qproperty-iconSize: 24px;
}

QPushButton[btn-type="primary"] {
    background-color: #4f46e5;
    color: white;
}
QPushButton[btn-type="primary"]:pressed {
    background-color: #312e81;
}

QPushButton[btn-type="success"] {
    background-color: #16A34A;
    color: white;
}
QPushButton[btn-type="success"]:pressed {
    background-color: #166534;
}

QPushButton[btn-type="neutral"] {
    background-color: #e5e7eb;
    border: 1px solid #d1d5db;
    color: #374151;
}
QPushButton[btn-type="neutral"]:pressed {
    background-color: #9ca3af;
}

QPushButton[btn-type="link"] {
    color: #374151;
    font-size: 14px;
    border: 0px;
    background-color: transparent;
}
QPushButton[btn-type="link"]:pressed {
    color: #1f2937;
}

QPushButton[btn-type="danger"] {
    background-color: #DC2626;
    color: white;
}
QPushButton[btn-type="danger"]:pressed {
    background-color: #991b1b;
}

QPushButton:disabled {
    background-color: #f3f4f6;
    border: 1px solid #e5e7eb;
    color: #9ca3af;
}

QPushButton#score_btn_1 {
    background-color: @CANVAS;
    border: 1px solid @SCORE_HIGH_BORDER;
    color: @SCORE_HIGH_TEXT;
    font-weight: bold;
    border-radius: 6px;
}
QPushButton#score_btn_2 {
    background-color: @CANVAS;
    border: 1px solid @SCORE_MID_BORDER;
    color: @SCORE_MID_TEXT;
    font-weight: bold;
    border-radius: 6px;
}
QPushButton#score_btn_3 {
    background-color: @CANVAS;
    border: 1px solid @SCORE_LOW_BORDER;
    color: @SCORE_LOW_TEXT;
    font-weight: bold;
    border-radius: 6px;
}

QPushButton#score_btn_1:checked {
    background-color: @SCORE_HIGH_BG;
    color: @CANVAS;
}
QPushButton#score_btn_2:checked {
    background-color: @SCORE_MID_BG;
    color: @CANVAS;
}
QPushButton#score_btn_3:checked {
    background-color: @SCORE_LOW_BG;
    color: @CANVAS;
}

/* QTextEdit */

QTextEdit[textedit-style="box"] {
    border: 1px solid #D1D5DB;
    border-radius: 8px;
    background-color: #F9FAFB;
    padding: 6px;
    font-size: 14px;
}

/* QProgressBar */

QProgressBar {
    border: none;
    background-color: #e0e7ff;     /* indigo-100 */
    border-radius: 3px;
}

QProgressBar::chunk {
    background-color: #4f46e5;     /* indigo-600 */
    border-radius: 3px;
}

/* --------- QComboBox --------- */

QComboBox {
    border: 1px solid #D1D5DB;
    background-color: #F2F3F5;
    border-radius: 8px;
    padding: 6px 6px 6px 10px;
    font-size: 14px;
    margin-bottom: 3px;
}
QComboBox::drop-down {
    border: 0px;
    background-color: #F2F3F5;
    width: 20px;
    border-radius: 8px;
    padding-right: 5px;
}
QComboBox::down-arrow {
    image: url(gui/resources/icons/arrow_down.png);
    width: 12px;
    height: 12px;
    /* background-color: white; */
}
/* QComboBox тізімі */
QComboBox QAbstractItemView {
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    background-color: white;
    selection-background-color: #aaddff;
    color: #333;
    margin-top: 3px;
    padding: 6px 6px 6px 6px;
}

/* ------ Table Widget ------ */

QTableView#main_table {
    border: 1px solid @BORDER;
    border-radius: 8px;
    background-color: @CANVAS;
}

QTableView#frozen_column {
    border: none;
    border-right: 1px solid @BORDER;
    border-top-left-radius: 8px;
    border-top-right-radius: 0px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    background-color: @CANVAS;
}

QTableView QHeaderView {
    border: none;
    border-bottom: 1px solid @BORDER;
    border-top-left-radius: 8px;
    border-top-right-radius: 0px;
    background-color: @HEADER_CELL_BACKGROUND;
    font-weight: bold;
    color: @TEXT_MAIN;
}

QTableView QHeaderView::section:horizontal {
    border: none;
    background-color: transparent;
}

QTableView::item {
    padding: 0px;
    margin: 0px;
    font-weight: 400;
    font-size: 14px;
    color: @CELL_TEXT;
    border: 0px;
}

QTableView::item:selected {
    background-color: @CELL_SELECTED_BG;
    color: @CANVAS;
}

/* ------ Scroll Bar ------ */

QScrollBar:vertical {
    border: none;
    background: @SCROLLBAR_TRACK;
    width: 10px;
    margin: 0px 0px 0px 0px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    padding-top: 4px;
}

QScrollBar::handle:vertical {
    background: @SCROLLBAR_HANDLE;
    min-height: 30px;
    border-radius: 5px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: @SCROLLBAR_HOVER_HANDLE;
}

QScrollBar::add-line:vertical, 
QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar::add-page:vertical, 
QScrollBar::sub-page:vertical {
    background: none;
}

QAbstractScrollArea::corner {
    background: @SCROLLBAR_TRACK;
    border-bottom-right-radius: 8px;
    border: none;
}

/* Horizontal Scroll Bar */

QScrollBar:horizontal {
    border: none;
    background: @SCROLLBAR_TRACK;
    height: 10px;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    padding-left: 4px;
}

QScrollBar::handle:horizontal {
    background: @SCROLLBAR_HANDLE;
    min-width: 30px;
    border-radius: 5px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background: @SCROLLBAR_HOVER_HANDLE;
}

QScrollBar::add-line:horizontal, 
QScrollBar::sub-line:horizontal {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar::add-page:horizontal, 
QScrollBar::sub-page:horizontal {
    background: none;
}

/* QSpinBox */

QSpinBox::up-arrow {
    image: url(gui/resources/icons/arrow_drop_up.png);
    width: 16px;
    height: 16px;
}

QSpinBox::down-arrow {
    image: url(gui/resources/icons/arrow_drop_down.png); 
    width: 16px;
    height: 16px;
}

/* QFrame */

QFrame[frame-style="box"] {
    border: 1px solid #D1D5DB;
    border-radius: 8px;
    padding: 0px;
    margin: 0px;
}

QFrame[frame-style="status-loading"] {
    border: 1px solid @BORDER;
    border-radius: 30px;
    background-color: @BG;
}
QFrame[frame-style="status-success"] {
    border: 1px solid @BORDER;
    border-radius: 30px;
    background-color: @SUCCESS;
}
QFrame[frame-style="status-error"] {
    border: 1px solid @BORDER;
    border-radius: 30px;
    background-color: @ERROR;
}

QFrame[frame-style="blank"] {
    padding: 0px;
    margin: 0px;
}

QFrame#separator {
    border-top: 1px solid @BORDER;
}